{
  "name": "custom-wan",
  "version": "1.0.0",
  "private": true,
  "description": "Local ComfyUI and Wan 2.2 bootstrap installer and launcher.",
  "homepage": "https://comfyui.reallexi.io/",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "check": "npm test && pwsh -NoProfile -File tests/validate.ps1",
    "test": "pwsh -NoProfile -File tests/run.ps1",
    "wnew": "pwsh -NoProfile -File install.ps1 -Cuda cu128 -Models 5b -WithManager -Start",
    "wstart": ".\\ComfyUI\\.venv\\Scripts\\python.exe wan2_cli.py start --path .",
    "lstart": "./ComfyUI/.venv/bin/python wan2_cli.py start --path ."
  },
  "keywords": [
    "comfyui",
    "wan",
    "ai-video",
    "local-ai"
  ],
  "license": "MIT",
  "type": "commonjs"
}
